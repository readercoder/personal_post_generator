# ──────────────────────────────────────────────────────────────────────────────
# Google Sheets (Service Account)
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/google-service-account.json
GOOGLE_SHEET_ID=1T9wfq1miOox6PZOAvwu4qDbueYYhcKtnBIFOtwIhKiQ
GOOGLE_SHEET_TAB=Post_Pipeline

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI — REMOVED. Using NVIDIA NIM for text generation instead.
# ──────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...  (no longer needed)

# ──────────────────────────────────────────────────────────────────────────────
# NVIDIA NIM — ONE KEY for BOTH text generation AND image generation
# Get key at: https://build.nvidia.com → Get API Key
# ──────────────────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-...

# Text model — swap to any NVIDIA NIM chat model:
#   meta/llama-3.3-70b-instruct        ← default (fast + high quality)
#   meta/llama-3.1-405b-instruct       ← best quality, slower
#   nvidia/llama-3.3-nemotron-super-49b-v1.5  ← NVIDIA fine-tune
#   mistralai/mistral-large            ← great writing style
NIM_TEXT_MODEL=meta/llama-3.3-70b-instruct

# ──────────────────────────────────────────────────────────────────────────────
# LinkedIn
# Run: npm run get-linkedin-token   — to get your access token
# PERSON_URN: run  curl -H "Authorization: Bearer TOKEN" https://api.linkedin.com/v2/me
# ORG_URN:    your company page URL → linkedin.com/company/YOUR_NUMBER/admin
# ──────────────────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_app_client_id
LINKEDIN_CLIENT_SECRET=your_app_client_secret
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_PERSON_URN=your_person_id_here
LINKEDIN_ORG_URN=your_org_id_here

# ──────────────────────────────────────────────────────────────────────────────
# Pipeline Config
# ──────────────────────────────────────────────────────────────────────────────
# DRY_RUN=true  →  full pipeline runs & logs but does NOT publish to LinkedIn
DRY_RUN=false
# Cron schedule (default: 8:00 AM daily)
CRON_SCHEDULE=0 8 * * *
# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
